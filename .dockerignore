# Exclude everything by default, whitelist what the build actually needs
*

# Build config & lock files
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!tsconfig.json
!nuxt.config.ts
!content.config.ts
!prisma.config.ts
!.nuxtignore

# Source code directories Nuxt/Nitro needs
!app/
!server/
!public/
!scripts/
!patches/

# Explicitly block heavy stuff that got whitelisted by !server/ above
server/config/
electronAssets/
android/
ios/
icons/
docs/

# Runtime env is injected at container start, never baked in
.env
.env.*

# Never send these
node_modules/
.output/
.nuxt/
.data/
dist/
dist-electron/
bun.lock
bun.lockb
*.log
.git/
.vscode/