# =============================================================================
# macOS Code Signing & Notarization
# =============================================================================
# For macOS notarization using Bash scripting
# export MAC_NOTARIZE=true
export MAC_CODE_SIGN_IDENTITY="Developer ID Application: Your Name (TeamID)"
export APPLE_ID="your-apple-id@example.com"
export APPLE_ID_PASS="your-app-specific-password"

# =============================================================================
# Windows Code Signing (Works from Linux/macOS/Windows)
# =============================================================================
# Option 1: Standard .pfx Certificate File (Recommended for most users)
# ---------------------------------------------------------------------------
# Place your .pfx certificate file at: electronAssets/builder/envs/Cert.pfx
# Then set the path and password below:
export WIN_CSC_LINK="electronAssets/builder/envs/Cert.pfx"
# Or use absolute path:
# export WIN_CSC_LINK="/home/bader/Desktop/portfolio/electronAssets/builder/envs/Cert.pfx"
export WIN_CSC_KEY_PASSWORD="your-certificate-password"

# Option 2: Base64-Encoded Certificate (Useful for CI/CD)
# ---------------------------------------------------------------------------
# Convert your .pfx to base64: base64 -w 0 Cert.pfx
# Then prefix with "base64:":
# export WIN_CSC_LINK="base64:MII... (your base64-encoded certificate content)"
# export WIN_CSC_KEY_PASSWORD="your-certificate-password"

# Option 3: Azure Trusted Signing (Cloud-based, recommended for CI/CD)
# ---------------------------------------------------------------------------
# Requires Azure account and Trusted Signing resource
# Comment out WIN_CSC_LINK and WIN_CSC_KEY_PASSWORD when using Azure
# export WIN_CSC_LINK=""
# export WIN_CSC_KEY_PASSWORD=""
# export AZURE_TENANT_ID="your-azure-tenant-id"
# export AZURE_CLIENT_ID="your-azure-client-id"
# export AZURE_CLIENT_SECRET="your-azure-client-secret"
# export AZURE_ENDPOINT="https://eus.codesigning.azure.net/"
# export AZURE_CERT_PROFILE_NAME="your-certificate-profile-name"

# =============================================================================
# Testing Without Code Signing
# =============================================================================
# For testing builds without signing, simply comment out or remove the
# WIN_CSC_LINK and WIN_CSC_KEY_PASSWORD variables above.
# The build will proceed without code signing (apps will show "Unknown Publisher")
# =============================================================================
