  "scripts": {
    "build": "nuxt build",
    "build:client": "NUXT_SSR=false nuxt build",
    "dev": "nuxt dev",
    "dev:electron": "NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxt dev # ❌ yet need maintenance",
    "build:electron": "NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxt generate && electron-builder --config=electronAssets/builder/config.js",
    "generate": "NUXT_GZIP=false IS_CAPACITOR=true nuxt generate --dotenv .env.capacitor",
    "generate:client": "NUXT_SSR=false nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --cache",
    "typecheck": "nuxi typecheck",
    "start": "node .output/server/index.mjs",
    "test": "bun lint && bun typecheck",
    "vapid-generate": "web-push generate-vapid-keys [--json]"
  },
