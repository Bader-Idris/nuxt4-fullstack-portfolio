{
  "name": "nuxt4-fullstack-portfolio",
  "private": true,
  "version": "3.2.4",
  "main": "dist-electron/main.js",
  "appId": "com.baderidris.www",
  "author": "Bader Idris <contact@baderidris.com> (http://baderidris.com/)",
  "description": "nuxt 4 production ready battle tested full stack portfolio with socket.io nginx dockerized pinia storing motions with gsap and capacitor for mobiles and electron for desktops",
  "prisma": {
    "schema": "./server/prisma/schema.prisma"
  },
  "scripts": {
    "old:prebuild": "bunx prisma migrate deploy && bunx prisma generate --schema ./server/prisma/schema.prisma",
    "prebuild": "npx prisma generate",
    "build": "nuxt build",
    "build:client": "NUXT_SSR=false nuxt build",
    "dev": "bun prebuild && nuxt dev",
    "dev:electron": "bun prebuild && NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxt dev",
    "build:electron": "bun prebuild && IS_ELECTRON=true NUXT_GZIP=false nuxi build --prerender && electron-builder --config=./electronAssets/builder/config.js",
    "build:electron:all": "NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxt generate && electron-builder --config=./electronAssets/builder/config.js -wml",
    "build:electron:win": "NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxt generate && electron-builder --config=./electronAssets/builder/config.js --windows",
    "build:electron:mac": "NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxt generate && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config=./electronAssets/builder/config.js  --mac",
    "build:electron:linux": "NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxt generate && electron-builder --config=./electronAssets/builder/config.js --linux",
    "build:electron:dir": "NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxt generate && electron-builder --config=./electronAssets/builder/config.js --dir",
    "generate": "bun prebuild && NUXT_GZIP=false IS_CAPACITOR=true nuxt generate --dotenv .env.capacitor",
    "generate:client": "NUXT_SSR=false nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && patch-package",
    "lint": "eslint . --cache",
    "typecheck": "nuxi typecheck",
    "start": "node .output/server/index.mjs",
    "test": "bun lint && bun typecheck",
    "vapid-generate": "web-push generate-vapid-keys [--json]"
  },
  "dependencies": {
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@nuxt/content": "^3.7.1",
    "@nuxt/icon": "^2.0.0",
    "@nuxt/image": "^1.11.0",
    "@nuxt/scripts": "^0.12.1",
    "@nuxt/test-utils": "^3.19.2",
    "@nuxtjs/device": "^3.2.4",
    "@nuxtjs/i18n": "^10.1.0",
    "@pinia/nuxt": "^0.11.2",
    "@prisma/nuxt": "^0.3.0",
    "@rive-app/canvas": "^2.31.6",
    "@socket.io/redis-streams-adapter": "^0.2.2",
    "@vite-pwa/nuxt": "^1.0.4",
    "@vueuse/nuxt": "^13.9.0",
    "animate.css": "^4.1.1",
    "apn": "^2.2.0",
    "bcryptjs": "^3.0.2",
    "canvas-confetti": "^1.9.3",
    "firebase-admin": "^13.5.0",
    "highlight.js": "^11.11.1",
    "howler": "^2.2.4",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.8.7",
    "nodemailer": "^7.0.7",
    "nuxt": "^4.1.2",
    "particles.js": "^2.0.0",
    "pinia": "^3.0.3",
    "rate-limiter-flexible": "^8.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "v-gsap-nuxt": "^1.4.4",
    "vue": "latest",
    "vue-router": "latest",
    "vue3-toastify": "^0.2.8",
    "web-push": "^3.6.7"
  },
