{
  "name": "nuxt4-fullstack-portfolio",
  "version": "3.2.4",
  "private": true,
  "description": "nuxt 4 production ready battle tested full stack portfolio with socket.io nginx dockerized pinia storing motions with gsap and capacitor for mobiles and electron for desktops",
  "author": "Bader Idris <contact@baderidris.com> (http://baderidris.com/)",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "old:prebuild": "bunx prisma migrate deploy && bunx prisma generate --schema ./server/prisma/schema.prisma",
    "prebuild": "npx prisma generate",
    "migrate:deploy": "npx prisma migrate deploy && npx prisma generate",
    "build": "nuxt build",
    "build:client": "NUXT_SSR=false nuxt build",
    "dev": "bun prebuild && nuxt dev",
    "dev:electron": "bun prebuild && NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxt dev",
    "build:electron": "bun prebuild && NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxi build --prerender --dotenv .env.electron && electron-builder --config=./electronAssets/builder/config.js",
    "build:electron:all": "bun prebuild && NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxi build --prerender --dotenv .env.electron && electron-builder --config=./electronAssets/builder/config.js -wml",
    "build:electron:win": "bun prebuild && NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxi build --prerender --dotenv .env.electron && electron-builder --config=./electronAssets/builder/config.js --windows",
    "build:electron:mac": "bun prebuild && NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxi build --prerender --dotenv .env.electron && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config=./electronAssets/builder/config.js  --mac",
    "build:electron:linux": "bun prebuild && NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxi build --prerender --dotenv .env.electron && electron-builder --config=./electronAssets/builder/config.js --linux",
    "build:electron:dir": "bun prebuild && NUXT_SSR=false IS_ELECTRON=true NUXT_GZIP=false nuxi build --prerender --dotenv .env.electron && electron-builder --config=./electronAssets/builder/config.js --dir",
    "generate": "bun prebuild && NUXT_GZIP=false IS_CAPACITOR=true nuxt generate --dotenv .env.capacitor",
    "generate:client": "NUXT_SSR=false nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && patch-package",
    "lint": "eslint . --cache",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "nuxi typecheck",
    "start": "node .output/server/index.mjs",
    "test": "bun lint && bun typecheck",
    "vapid-generate": "web-push generate-vapid-keys [--json]"
  },
  "dependencies": {
    "@capgo/capacitor-social-login": "^8.3.6",
    "@nuxt/content": "^3.11.2",
    "@nuxt/icon": "^2.2.1",
