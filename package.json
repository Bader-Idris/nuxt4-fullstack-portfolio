    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/flowbite": "^1.2.7",
    "@iconify-json/fluent": "^1.2.32",
    "@iconify-json/grommet-icons": "^1.2.3",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/hugeicons": "^1.2.17",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/ion": "^1.2.6",
    "@iconify-json/lineicons": "^1.2.6",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/ri": "^1.2.5",
    "@iconify-json/simple-icons": "^1.2.54",
    "@iconify-json/teenyicons": "^1.2.2",
    "@nuxt/eslint": "^1.9.0",
    "@nuxtjs/seo": "^3.2.2",
    "@tiptap/extension-code-block": "^3.6.5",
    "@tiptap/extension-image": "^3.6.5",
    "@tiptap/extension-link": "^3.6.5",
    "@tiptap/extension-table": "^3.6.5",
    "@tiptap/extension-table-cell": "^3.6.5",
